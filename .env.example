# Anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024

# Where /analyse_risk POSTs the aggregated result after the agent finishes.
# Leave empty in dev to skip the callback.
CALLBACK_URL=
CALLBACK_TIMEOUT_SECONDS=10

# Background worker for `enqueue_and_callback=true` requests.
# 0 disables the worker (the enqueue path will reject with 503).
JOB_WORKER_CONCURRENCY=1
JOB_QUEUE_MAX_SIZE=1000

# Database — Tortoise ORM
# Postgres example:  postgres://user:pass@localhost:5432/risk_control
# SQLite file:       sqlite:///./risk_control.sqlite3
# In-memory (tests): sqlite://:memory:
DATABASE_URL=sqlite://:memory:

# Default value for the `include_history` switch on POST /analyse_risk
# (per-request body field overrides this).
INCLUDE_HISTORY_DEFAULT=true

# High-risk filter — accounts whose max per-risk score is below this
# threshold are dropped from the response and from the callback to Alex.
# Stored rows in /analyses are unaffected.
CALLBACK_MIN_SCORE=60

# Cheap deterministic prescreen before the LLM. Risks that obviously
# cannot trip on the current snapshot are skipped (saves Anthropic tokens).
PRESCREEN_ENABLED=true

# Logging — DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
